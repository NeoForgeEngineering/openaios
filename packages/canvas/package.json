{
  "name": "@openaios/canvas",
  "version": "0.1.0",
  "description": "A2UI protocol for agent-driven visual workspaces over WebSocket",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

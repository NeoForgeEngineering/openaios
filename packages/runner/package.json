{
  "name": "@openaios/runner",
  "version": "0.1.0",
  "description": "Runner adapters for openAIOS (ClaudeCode, Ollama, Anthropic, OpenAI-compat)",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "tsx --test 'src/__tests__/**/*.test.ts'"
  },
  "dependencies": {
    "@openaios/core": "workspace:*",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.26.0",
    "ollama": ">=0.5.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesOptional": {
    "ollama": true,
    "openai": true,
    "@anthropic-ai/sdk": true
  }
}
